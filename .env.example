# TwinCart — environment template. Copy to .env and fill real values.
# .env is gitignored. NEVER put real secrets in this .example file.

# ─── AWS (host: Amplify/Lambda/App Runner, RDS, S3, Secrets Manager) ───
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# RDS Postgres connection string (pgvector enabled) — set after provisioning.
# Format: standard postgres connection URI (user, password, host, port 5432, db=twincart).
DATABASE_URL=
# S3 bucket for product images / Apify raw JSON
S3_BUCKET=twincart-assets

# ─── Apify (data layer — Amazon/Temu/SHEIN/Walmart/Target actors) ───
APIFY_TOKEN=

# ─── Box (savings reports + AP2 audit trail) ───
# Easiest for demo: a Developer Token (60-min expiry). Regenerate before demo.
BOX_DEVELOPER_TOKEN=
# OR Client Credentials Grant (longer-lived) — fill these instead if used:
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_ENTERPRISE_ID=
# Box folder ID where reports are saved (0 = root)
BOX_REPORTS_FOLDER_ID=0

# ─── LLM (offline batch: normalize / classify / verdict) ───
# Default: Anthropic API. (Alternative: AWS Bedrock-Claude, which uses the AWS creds above — no separate key.)
ANTHROPIC_API_KEY=
# Optional alternates (we default to Anthropic; these are available if needed):
OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_PROVIDER=anthropic            # anthropic | bedrock | openai | gemini
LLM_MODEL=claude-opus-4-8

# ─── UCP / AP2 ───
# ES256 signing key for AP2 mandates is generated at boot if unset (dev).
# UCP_SIGNING_KEY_PEM=
# Live external UCP merchant sandbox for the interop beat:
UCP_SANDBOX_URL=https://puddingheroes.com

# ─── Typesense (fast search at 10k–20k+ scale; `docker compose up -d typesense`) ───
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=twincart-dev

# ─── App ───
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
